<Project>

  <PropertyGroup>
    <!-- Standalone consumers do not inherit this repo's Directory.Build.props; default from the env var. -->
    <VintageStoryPath Condition="'$(VintageStoryPath)' == ''">$(VINTAGE_STORY)</VintageStoryPath>
  </PropertyGroup>

  <!--
    Shared fix for E2E consumers (test projects, samples) that both reference VintagestoryAPI
    directly and pull in dependencies (test SDKs, etc.) that transitively bring their own
    Newtonsoft.Json. That transitive copy (commonly 13.0.1, a plain NuGet release) lands in the
    consumer's own output directory and shadows the game's own copy - Newtonsoft.Json 13.0.4.30916,
    a Vintage Story-shipped build that is not a public NuGet release - because default assembly
    probing against the output directory wins over Atlas's AssemblyResolve fallback, which only
    runs once probing has already failed. VintagestoryLib/VintagestoryAPI are compiled against the
    exact game copy, so a mismatched version causes a MissingMethodException at runtime (e.g. inside
    ServerConfig.Save()) instead of a clear error. Import this file from any project that needs a
    real Vintage Story install for E2E/integration testing:

      <Import Project="..\..\build\Atlas.E2E.targets" />

    VintageStoryPath defaults from the VINTAGE_STORY environment variable for standalone consumers
    that do not inherit this repo's Directory.Build.props.
  -->

  <Target Name="CopyGameNewtonsoftJson" AfterTargets="Build"
          Condition="'$(VintageStoryPath)' != '' AND Exists('$(VintageStoryPath)\Lib\Newtonsoft.Json.dll')">
    <Copy SourceFiles="$(VintageStoryPath)\Lib\Newtonsoft.Json.dll"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="false" />
  </Target>

  <Target Name="WarnMissingGameNewtonsoftJson" AfterTargets="Build"
          Condition="'$(VintageStoryPath)' == '' OR !Exists('$(VintageStoryPath)\Lib\Newtonsoft.Json.dll')">
    <Warning Text="VintageStoryPath is unset or '$(VintageStoryPath)\Lib\Newtonsoft.Json.dll' does not exist: the game's Newtonsoft.Json will not be copied over the transitive NuGet copy, and E2E runs will likely fail at runtime with a MissingMethodException from Newtonsoft.Json instead of a clear setup error. Set the VINTAGE_STORY environment variable to a valid install." />
  </Target>

  <!--
    MSBuild staging sugar: a test project can reference its mod-under-test as an ordinary
    ProjectReference, tagged with <AtlasMod>true</AtlasMod>, instead of hand-writing a relative
    path into [assembly: AtlasMods(...)]:

      <ProjectReference Include="..\MyMod\MyMod.csproj">
        <AtlasMod>true</AtlasMod>
      </ProjectReference>

    _ResolvedProjectReferencePaths is the item MSBuild produces after resolving each
    ProjectReference to its actual build output (respecting the referenced project's own
    OutputType/TargetPath); custom metadata placed on the original ProjectReference item (like
    AtlasMod here) flows through onto the resolved item automatically, so no matching back by
    path or MSBuildSourceProjectFile is needed. This was confirmed empirically: building a
    throwaway consumer with a diagnostic target logging %(_ResolvedProjectReferencePaths.AtlasMod)
    showed the metadata present on the resolved item, unchanged.

    The manifest is written after ResolveProjectReferences (so the resolved paths exist) and
    before Build completes, directly into $(TargetDir) alongside the test assembly, one absolute
    path per line, via WriteLinesToFile(Overwrite=true) so re-builds do not append. If no
    ProjectReference carries AtlasMod=true, any stale manifest from a previous build (e.g. after
    removing the metadata) is deleted rather than left behind with outdated content.

    AttributeMapper (Atlas.XUnit) reads this file at test-discovery time, when present, and
    appends its paths after any [assembly: AtlasMods(...)] paths.

    Cost note: this file ships buildTransitive, so the target runs on every build of every
    package consumer. With no tagged references it is a cheap no-op (one item transform, one
    Exists check); that always-run cost is deliberate, it is what keeps the stale-manifest
    delete reliable on incremental builds (no Inputs/Outputs means no up-to-date skip).

    The TargetFramework condition skips the outer dispatch pass of a multi-targeting build
    (TargetFrameworks plural), where no per-TFM $(TargetDir) is meaningful; the inner
    per-framework passes each run the target normally.
  -->
  <Target Name="WriteAtlasModManifest" AfterTargets="ResolveProjectReferences" BeforeTargets="Build"
          Condition="'$(TargetFramework)' != ''">
    <ItemGroup>
      <_AtlasModReferencePath Include="@(_ResolvedProjectReferencePaths)" Condition="'%(_ResolvedProjectReferencePaths.AtlasMod)' == 'true'" />
    </ItemGroup>

    <MakeDir Directories="$(TargetDir)" Condition="'@(_AtlasModReferencePath)' != '' AND !Exists('$(TargetDir)')" />

    <WriteLinesToFile File="$(TargetDir)atlas-mods.generated.txt"
                       Lines="@(_AtlasModReferencePath)"
                       Overwrite="true"
                       Condition="'@(_AtlasModReferencePath)' != ''" />

    <Delete Files="$(TargetDir)atlas-mods.generated.txt"
            Condition="'@(_AtlasModReferencePath)' == '' AND Exists('$(TargetDir)atlas-mods.generated.txt')" />
  </Target>

</Project>
